FROM python:3.11-slim
WORKDIR /app

# Step 1 — packages that don't conflict with langchain-core 1.x
COPY requirements.txt .
RUN pip install --no-cache-dir \
    fastapi==0.115.6 \
    "uvicorn[standard]==0.32.1" \
    pydantic==2.10.3 \
    python-dotenv==1.0.1 \
    "httpx==0.28.1" \
    arxiv==2.1.3 \
    qdrant-client==1.12.1 \
    sentence-transformers==3.3.1 \
    langgraph==1.1.4

# Step 2 — langchain-groq without its strict langchain-core<0.4.0 constraint
# (langchain-core 1.x is API-compatible with langchain-groq 0.2.3 at runtime)
RUN pip install --no-cache-dir --no-deps langchain-groq==0.2.3 && \
    pip install --no-cache-dir "groq>=0.4.1"

COPY . .

CMD ["bash", "-c", "cd lore_v2 && uvicorn main_v2:app --host 0.0.0.0 --port 8001"]
